sysinfo.txt

# Personal notes / AI exports — not part of the game (local only under notes/)
notes/

# IDE / tooling
.vs/
.gradle/
.idea/

# Exported / local packages (prefer Git LFS or external storage for very large meshes/audio)
ExportedObj/

